                "exec": [
                  ""
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonResponse = pm.response.json();\r",
                  "const str = jsonResponse.files[0].filename;\r",
                  "var index = str.lastIndexOf(\"_\");\r",
                  "var result = str.substr(0, index+1);\r",
                  "pm.collectionVariables.set(\"filenameStartsWith\", result);\r",
                  "\r",
                  "// set last filename variable\r",
                  "let numberOfFiles = jsonResponse.files.length;\r",
                  "const latestFileEntry = jsonResponse.files[numberOfFiles-1];\r",
                  "let  latestFilename = latestFileEntry.filename;\r",
                  "pm.collectionVariables.set(\"latestFilename\", latestFilename);"
                ],
                "type": "text/javascript"
              }
            }
          ],

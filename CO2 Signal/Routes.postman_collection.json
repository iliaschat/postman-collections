              "value": "{{longitude}}",
              "description": "longitude"
            },
            {
              "key": "lat",
              "value": "{{latitude}}",
              "description": "latitude"
            }
          ]
        },
        "description": "This endpoint retrieves the last known state of the zone. Currently we default to zones by country, but this will quickly evolve to be as granular as possible."
